# ══════════════════════════════════════════════════
#   GrowthPilot AI v3 — Environment Variables
#   Copy this file to .env and fill in your keys
# ══════════════════════════════════════════════════

# ── SERVER ─────────────────────────────────────────
PORT=4000
BACKEND_URL=https://your-growthpilot-api.onrender.com
FRONTEND_URL=https://your-growthpilot.netlify.app

# ── ANTHROPIC (Claude AI) ──────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ── TWITTER / X API ────────────────────────────────
# Get from: developer.twitter.com → Projects & Apps
# Need: Basic plan ($100/mo) for posting, Free for reading trends
TWITTER_BEARER_TOKEN=AAAAAAAAAAAAAAAAAAAAAyour-bearer-token
TWITTER_API_KEY=your-api-key
TWITTER_API_SECRET=your-api-secret
TWITTER_ACCESS_TOKEN=your-access-token
TWITTER_ACCESS_SECRET=your-access-secret

# ── INSTAGRAM (Meta Graph API) ─────────────────────
# Get from: developers.facebook.com
# Steps: Create App → Add Instagram Product → Get Business Account ID
INSTAGRAM_ACCESS_TOKEN=your-long-lived-access-token
INSTAGRAM_BUSINESS_ID=your-instagram-business-account-id

# ── TIKTOK API ─────────────────────────────────────
# Get from: developers.tiktok.com → Manage Apps
# Need: Content Posting API access (apply separately)
TIKTOK_ACCESS_TOKEN=your-tiktok-access-token
TIKTOK_CLIENT_KEY=your-tiktok-client-key

# ── STRIPE ─────────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API Keys
# Use sk_test_xxx for testing, sk_live_xxx for production
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# Create products in Stripe Dashboard → get Price IDs
STRIPE_PRO_PRICE_ID=price_your-pro-plan-price-id
STRIPE_AGENCY_PRICE_ID=price_your-agency-plan-price-id

# ── M-PESA DARAJA ──────────────────────────────────
# Get from: developer.safaricom.co.ke
# Steps: Create App → Get Consumer Key & Secret
MPESA_CONSUMER_KEY=your-mpesa-consumer-key
MPESA_CONSUMER_SECRET=your-mpesa-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your-mpesa-passkey
MPESA_SANDBOX=true

# ── NEWS API (Live news feed) ─────────────────────────
# Get from: newsapi.org → Get API Key (free: 100 req/day)
# Used for: Live trending news in the trends section
NEWS_API_KEY=your-newsapi-key-here

# ── RESEND (Email receipts) ────────────────────────
# Get from: resend.com → API Keys (free plan works)
RESEND_API_KEY=re_your-resend-api-key
NOTIFY_EMAIL=your@email.com
